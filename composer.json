{
    "name": "akpagni5547/filament-gemini-search",
    "description": "Filament plugin for Gemini API search with Google Search Grounding",
    "keywords": ["filament", "gemini", "google", "search", "grounding", "laravel"],
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "filament/filament": "^3.0|^4.0|^5.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "SelfProject\\FilamentGeminiSearch\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "SelfProject\\FilamentGeminiSearch\\FilamentGeminiSearchServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
